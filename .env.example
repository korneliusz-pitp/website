# GitHub Configuration (for Nuxt Studio Git integration)
STUDIO_GITHUB_TOKEN=your_github_pat_token

# Google OAuth Configuration
STUDIO_GOOGLE_CLIENT_ID=your_google_client_id
STUDIO_GOOGLE_CLIENT_SECRET=your_google_client_secret

# Studio Moderators
STUDIO_GOOGLE_MODERATORS=email1@example.com,email2@example.com

# Cloudflare R2 Configuration
# Get these from https://dash.cloudflare.com/?to=/:account/r2/overview
S3_ACCESS_KEY_ID=your_r2_access_key_id
S3_SECRET_ACCESS_KEY=your_r2_secret_access_key
S3_ENDPOINT=https://your_account_id.r2.cloudflarestorage.com
S3_BUCKET=your-bucket-name
S3_REGION=auto
S3_PUBLIC_URL=https://pub-your_hash.r2.dev
