# GitHub Configuration (for Nuxt Studio Git integration)
STUDIO_GITHUB_TOKEN=your_github_pat_token

# Google OAuth Configuration
STUDIO_GOOGLE_CLIENT_ID=your_google_client_id
STUDIO_GOOGLE_CLIENT_SECRET=your_google_client_secret

# Studio Moderators
STUDIO_GOOGLE_MODERATORS=email1@example.com,email2@example.com
